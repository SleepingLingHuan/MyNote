{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyNote",
  "version": "0.1.0",
  "identifier": "com.mynote.local",
  "build": {
    "beforeDevCommand": "python3 -m http.server 5173 --bind 127.0.0.1 --directory web",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MyNote",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
